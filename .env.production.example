# ============================================================
# IEC ELECTION PORTAL - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# IMPORTANT: Copy this to .env.production and fill with actual values
# NEVER commit actual .env files to version control

# -----------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------
# Public URL for client-side Supabase access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key for client-side operations
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key for server-side admin operations
# KEEP THIS SECRET - has full database access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------
# Gmail for official IEC communications
IEC_GMAIL_USER=your-official-iec-email@gmail.com
IEC_GMAIL_APP_PASSWORD=your-gmail-app-password

# Resend API for transactional emails (recommended)
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your_actual_api_key_here

# -----------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------
# Session secret for JWT tokens (generate with: openssl rand -base64 32)
SESSION_SECRET=your-32-byte-random-secret-here

# Admin credentials (CHANGE THESE IN PRODUCTION)
ADMIN_EMAIL=admin@iec-election.org
ADMIN_PASSWORD=your-secure-admin-password-here

# -----------------------------------------------------------
# PRODUCTION SETTINGS
# -----------------------------------------------------------
# Node environment (set to 'production' for production)
NODE_ENV=production

# Production URL for CORS and security headers
PRODUCTION_URL=https://your-domain.com

# -----------------------------------------------------------
# OPTIONAL: MONITORING & ANALYTICS
# -----------------------------------------------------------
# Sentry for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn-here

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# -----------------------------------------------------------
# DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION
# -----------------------------------------------------------
# These should be commented out or removed in production
# NEXT_PUBLIC_DEBUG=true
# SKIP_AUTH=true
