{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "alsi-iec-portal",

  "compatibility_date": "2026-05-09",

  "compatibility_flags": [
    "nodejs_compat"
  ],

  "observability": {
    "enabled": true
  },

  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
