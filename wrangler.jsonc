{
  "$schema": "./node_modules/wrangler/config-schema.json",

  "name": "alsi-iec-portal",

  "main": ".open-next/worker.js",

  "compatibility_date": "2026-05-09",

  "workers_dev": true,

  "compatibility_flags": [
    "nodejs_compat"
  ],

  "assets": {
    "directory": ".open-next/assets"
  },

  "observability": {
    "enabled": true
  }
}